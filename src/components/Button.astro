---
interface Props {
  label: string;
  href?: string;
  size?: "large" | "small";
}

const { label, href = "#", size = "large" } = Astro.props;
---

<a href={href} class:list={["btn", size === "small" ? "btn--small" : "btn--large"]}>
  {label}
</a>

<style>
  .btn {
    display: inline-block;
    font-family: "lacquer", sans-serif;
    font-weight: 400;
    font-style: normal;
    text-decoration: none;
    letter-spacing: 0.06em;
    border-radius: 15px;
    cursor: pointer;
    line-height: 1;
    background-color: var(--color-light-green);
    color: var(--color-text);
    border: 2.5px solid var(--color-black);
    box-shadow: none;

    transition:
      background-color 0.12s ease,
      color 0.12s ease,
      box-shadow 0.08s ease;
  }

  .btn--large {
    padding: clamp(0.55rem, 1.5vw, 0.75rem) clamp(1.2rem, 4vw, 2.5rem);
    font-size: clamp(0.9rem, 2vw, 1.25rem);
  }

  .btn--small {
    padding: clamp(0.4rem, 1.2vw, 0.6rem) clamp(1rem, 3vw, 1.8rem);
    font-size: clamp(0.9rem, 1.6vw, 1.1rem);
    border-radius: 10px;
  }

  .btn:hover {
    background-color: #2e8b2e;
    color: var(--color-text-inverted);
  }

  .btn:active {
    background-color: #1a5e1a;
    color: var(--color-text-inverted);
    box-shadow: inset 0 4px 10px rgba(0, 0, 0, 0.35);
  }
</style>
