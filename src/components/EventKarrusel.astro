      <div class="slides-container">
        {
          events.map((event, i) => (
            <div class="slide" data-index={i}>
              <EventCard
                title={event.title}
                text={event.text}
                image={event.image}
                dato={event.dato}
                href={event.href}
              />
            </div>
          ))
        }
      </div>
    </div>

    <button class="burst-btn mobil-næste næste" aria-label="Næste">
