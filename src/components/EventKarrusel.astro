---
import EventCard from "./EventCard.astro";

interface Event {
  title: string;
  text: string;
  image: string;
  dato?: string;
  tid?: string;
  href?: string;
}

interface Props {
  events: Event[];
  titel?: string;
  undertitel?: string;
}

const { events, titel, undertitel } = Astro.props;
---

<section class="event-karrusel">
  <div class="karrusel-header">
    {titel && <h2 class="karrusel-titel">{titel}</h2>}
    <div class="desktop-navigation">
      <button class="burst-btn forrige" aria-label="Forrige">
