<style>
  .event-karrusel {
    padding: 2rem 0;
    text-align: center;
  }

  .undertitel {
    margin-bottom: 3rem;
    margin-top: -1rem;
  }

  .karrusel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .desktop-navigation {
    display: none;
    gap: 0.5rem;
  }

  .karrusel-titel {
    text-align: center;
    width: 100%;
    margin: 0;
  }

  .karrusel-indre {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .slides-viewport {
    flex: 1;
    overflow: hidden;
    min-width: 0;
  }

  .slides-container {
    display: flex;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    align-items: flex-start;
  }

  .slide {
    min-width: 100%;
    flex-shrink: 0;
  }

  .burst-btn {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    cursor: pointer;
    border: none;
    background: transparent;
    padding: 0;
    transition: transform 0.12s ease;
    --burst-fill: #fc9bf2;
    --burst-stroke: #ec0464;
    --arrow-stroke: #ec0464;
  }

  .burst-btn:hover {
    --burst-fill: #7fd4ff;
    --burst-stroke: #0b4ac9;
    --arrow-stroke: #0b4ac9;
  }

  .burst-btn:active {
    --burst-fill: #d99af0;
    --burst-stroke: #825194;
    --arrow-stroke: #825194;
  }

  .burst-svg {
    width: 100%;
    height: 100%;
  }

  @media (min-width: 580px) {
    .event-karrusel {
      text-align: left;
    }

    .karrusel-titel {
      text-align: left;
      width: auto;
    }
    .burst-btn {
      width: 80px;
      height: 80px;
    }
    .undertitel {
      margin-top: -2rem;
    }
    .desktop-navigation {
      display: flex;
    }

    .mobil-forrige,
    .mobil-næste {
      display: none;
    }

    .slides-viewport {
      width: 100%;
    }

    .slides-container {
      gap: 1rem;
    }

    .slide {
      min-width: calc((100% - 1rem) / 2);
      max-width: calc((100% - 1rem) / 2);
    }
  }

  @media (min-width: 960px) {
    .slide {
      min-width: calc((100% - 2rem) / 3);
      max-width: calc((100% - 2rem) / 3);
    }
  }
</style>

<script>
  document.querySelectorAll(".event-karrusel").forEach((karrusel) => {
    const slides = Array.from(
      karrusel.querySelectorAll(".slide"),
    ) as HTMLElement[];
    const container = karrusel.querySelector(
      ".slides-container",
    ) as HTMLElement;
    const viewport = karrusel.querySelector(".slides-viewport") as HTMLElement;
    let aktivSlide = 0;
    let isAnimating = false;

    function getSlidesPerView() {
      const w = window.innerWidth;
      if (w >= 960) return 3;
      if (w >= 580) return 2;
      return 1;
    }

    function getSlideWidth() {
      const per = getSlidesPerView();
      if (per > 1) {
        const gap = 16;
        const slideWidth = (viewport.offsetWidth - gap * (per - 1)) / per;
        return slideWidth + gap;
      }
      return viewport.offsetWidth;
    }

    function updateTransform() {
      container.style.transform = `translateX(-${aktivSlide * getSlideWidth()}px)`;
    }

    function forrige() {
      if (isAnimating || aktivSlide === 0) return;
      isAnimating = true;
      const per = getSlidesPerView();
      aktivSlide = Math.max(0, aktivSlide - per);
      updateTransform();
      setTimeout(() => {
        isAnimating = false;
      }, 400);
    }

    function næste() {
      if (isAnimating) return;
      const per = getSlidesPerView();
      const maxSlide = slides.length - per;
      if (aktivSlide >= maxSlide) return;
      isAnimating = true;
      aktivSlide = Math.min(maxSlide, aktivSlide + per);
      updateTransform();
      setTimeout(() => {
        isAnimating = false;
      }, 400);
    }

    function checkCentering() {
      const per = getSlidesPerView();
      if (slides.length <= per) {
        container.style.justifyContent = "center";
        karrusel.querySelectorAll(".burst-btn").forEach((btn) => {
          (btn as HTMLElement).style.visibility = "hidden";
        });
      } else {
        container.style.justifyContent = "";
        karrusel.querySelectorAll(".burst-btn").forEach((btn) => {
          (btn as HTMLElement).style.visibility = "";
        });
      }
    }

    karrusel
      .querySelectorAll(".forrige")
      .forEach((btn) => btn.addEventListener("click", forrige));
    karrusel
      .querySelectorAll(".næste")
      .forEach((btn) => btn.addEventListener("click", næste));

    checkCentering();

    window.addEventListener("resize", () => {
      aktivSlide = 0;
      updateTransform();
      checkCentering();
    });
  });
</script>
