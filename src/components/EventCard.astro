---
import CTA1 from "./Button.astro";

interface Props {
  title: string;
  text: string;
  image: string;
  dato?: string;
  tid?: string;
  type: string;
  href?: string;
}

const { title, text, image, dato, tid, type, href } = Astro.props;
---

<article class="event-card">
  <div class="event-card__billede">
    <img src={image} alt={title} />
  </div>
  <div class="event-card__indhold">
    <div class="event-card__header">
      <h3>{title}</h3>
      {href && <CTA1 text="Se mere" href={href} />}
    </div>
    {
      (dato || tid) && (
        <p class="event-card__meta">
          {dato && <span>{dato}</span>}
          {tid && <span>{tid}</span>}
        </p>
      )
    }
    <p class="event-card__tekst">{text}</p>
  </div>
</article>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .event-card__billede img {
    width: 100%;
    border-radius: 16px;
    object-fit: cover;
  }

  .event-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .event-card__meta {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
    color: var(--color-text);
    opacity: 0.7;
  }

  .event-card__tekst {
    line-height: 1.6;
  }
</style>
