---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
---

<html lang="da">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="/style/general.css" />
    <title>Nørrebro Späti</title>
  </head>
  <body>
    <Header />
    <main>
      <Layout title="Nørrebro Späti">
        <Hero />
      </Layout>

      <section class="intro">
        <h1 class="intro__heading">Kiosk & bar</h1>
        <h2>your fav hang-out spot</h2>
        <p>
          Vi er ikke helt en kiosk og ikke helt en bar. Vi er det sted du
          stikker forbi når du ikke har en plan, men alligevel ender med at
          blive til langt ud på aftenen. Vi sælger naturvin, snacks, tøj og alt
          muligt andet spøjst. Men mest af alt sælger vi en god aften med folk
          fra kvarteret.
        </p>
      </section>

      <div class="feature-photo">
        <img src="/img/collage.png" alt="Nørrebro Späti interiør" />
      </div>

      <div class="angel">
        <img src="/img/musikengel.svg" alt="Engel der spiller på fløjte" />
      </div>

      <section class="cards">
        <div class="cards__item">
          <Card
            title="vores udvalg"
            description="Mad, drikke, ting og sager"
            image="/img/mate.jpg"
            imageAlt="Club-Mate flaske"
            href="/sortiment"
          />
        </div>
        <div class="cards__item">
          <Card
            title="events og arrangementer"
            description="Din yndlingskiosk hoster selvfølgelig også dine yndlingsevents"
            image="/img/events.jpg"
            imageAlt="Stemningsbillede fra event"
            href="/events"
          />
        </div>
      </section>

      <div class="cta">
        <img
          class="cta__img"
          src="/img/nummi.svg"
          alt="Illustreret figur med bar numse"
        />
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  body {
    margin: 0;
    padding: 0;
    background-color: var(--color-text-inverted);
  }

  .intro {
    text-align: center;
    padding: 5rem 1.5rem 2rem;
    max-width: 380px;
    margin: 0 auto;
  }

  .intro__heading {
    margin: 0 0 0.3rem;
  }

  .feature-photo {
    display: flex;
    justify-content: center;
    padding: 2.5rem 1.5rem;
  }

  .feature-photo img {
    width: 100%;
    max-width: 350px;
    height: auto;
    display: block;
  }

  .angel {
    display: flex;
    justify-content: center;
    padding: 1rem 1.5rem 3rem;
  }

  .angel img {
    width: 180px;
    height: auto;
    padding: 20px;
  }

  .cards {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 360px;
    margin: 0 auto;
    justify-content: center;
    align-items: center;
  }

  .cards__item {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }

  .madogdrikke {
    padding-bottom: 10px;
  }

  .cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 6rem 2rem 3rem;
  }

  @media (min-width: 720px) {
    .cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: start;
      max-width: 800px;
    }

    .card-description {
      max-width: 800px;
    }

    .cards__item {
      display: grid;
      grid-template-rows: subgrid;
      grid-row: span 4;
    }

    .feature-photo {
      display: flex;
      justify-content: center;
      padding: 2.5rem 1.5rem;
    }

    .feature-photo img {
      width: 100%;
      max-width: 700px;
      height: auto;
      display: block;
    }

    .intro {
      text-align: center;
      padding: 5rem 1.5rem 2rem;
      max-width: 600px;
      margin: 0 auto;
    }
    .angel {
      display: flex;
      justify-content: center;
      padding: 1rem 1.5rem 3rem;
    }

    .angel img {
      width: 250px;
      height: auto;
      padding: 20px;
    }

    .cta {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding-top: 80px;
      padding-bottom: 30px;
    }
  }

  .cta__img {
    width: 100%;
    max-width: 700px;
    height: auto;
    display: block;
  }
</style>
