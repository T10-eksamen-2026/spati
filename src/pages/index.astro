---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
---

<html lang="da">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/public/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="/style/general.css" />
    <title>Nørrebro Späti</title>
  </head>
  <body>
    <Header background="var(--color-pink)" hoverColor="#fff" />
    <main>
      <Layout title="Nørrebro Späti">
        <Hero />
      </Layout>
      <section>
        <h1>Kiosk & bar</h1>
        <h2>Your fav hang-out spot</h2>
        <p>
          Vi er ikke helt en kiosk og ikke helt en bar. Vi er det sted du
          stikker forbi når du ikke har en plan, men alligevel ender med at
          blive til langt ud på aftenen. Vi sælger naturvin, snacks, tøj og alt
          muligt andet spøjst. Men mest af alt sælger vi en god aften med folk
          fra kvarteret.
        </p>
      </section>
      <img src="/public/img/musikengel.svg" alt="engel der spiller på fløjte" />
      <div class="btn-demo">
        <Button label="tag mig derhen" size="large" />
        <Button label="se mere" size="small" />
        <Button label="tilmeld" size="small" />
      </div>
      <Card
        title="vores udvalg"
        description="Mad, drikke, ting og sager"
        image="/mate.jpg"
        imageAlt="Club-Mate flaske"
        href="/single"
      />
      <Card
        title="Events og arrangementer"
        description="Din yndlingskiosk hoster selvfølgelig også dine yndlingsevents "
        image="/events.jpg"
        imageAlt="stemningsbillede fra event"
        href="/single"
      />
      <img src="/public/img/nummi.svg" alt="illustreret figur med bar numse" />
    </main>
    <Footer />
  </body>
</html>

<style>
  body {
    margin: 0;
    padding: 0;
    font-family: sans-serif;
    background-color: var(--color-text-inverted);
  }

  .btn-demo {
    padding: 4rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
  }

  img {
    max-width: 100%;
    height: auto;
  }
</style>
