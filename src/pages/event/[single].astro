---
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Button from "../../components/Button.astro";

export async function getStaticPaths() {
  const options = {
    headers: {
      apikey:
        "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpqbXpqZXl3em9ubWhyeHBpZG1lIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgzMzM1NDMsImV4cCI6MjA5MzkwOTU0M30._zazZivT85MElhidAI4pC61XTiWwx7NmS19ru3aUjPo",
    },
  };

  const response = await fetch(
    "https://zjmzjeywzonmhrxpidme.supabase.co/rest/v1/event_card",
    options,
  );
  const data = await response.json();

  return data.map((event: any) => ({
    params: { single: String(event.id) },
    props: { event },
  }));
}

interface Event {
  id: number;
  titel: string;
  teaser: string;
  info: string;
  billede: string;
  type: string;
  dato: string;
  tid: string;
  href: string;
}

interface Props {
  event: Event;
}

const { event } = Astro.props as Props;
---

<html lang="da">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="/style/general.css" />
    <title>{event.titel}</title>
  </head>

  <body>
    <Header
      background="var(--color-text-inverted)"
      hoverColor="var(--color-green)"
    />

    <main>
      <section class="kulturnat">
        <h1>{event.titel}</h1>
        <h2 class="dato">{event.dato} kl. {event.tid}</h2>
        <img class="poster" src={event.billede} alt={event.titel} />
        <div class="cta">
          <Button label="tilmeld" size="small" />
        </div>
        <div class="content">
          <p>
            {event.info}
          </p>

          <h3>Vedbækgade 4, 2200 København N</h3>
        </div>
      </section>

      <section class="bar-section">
        <img src="/img/bar.png" alt="illustration af bar" class="bar-image" />
      </section>

      <section class="events">
        <h2>upcoming events</h2>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  body {
    margin: 0;
    padding: 0;
    background-color: var(--color-text-inverted);
  }

  .kulturnat {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
  }
  .kulturnat h1 {
    grid-column: 1 / 2;
    grid-row: 1/2;
  }

  .kulturnat h2 {
    grid-column: 1 / 2;
    grid-row: 2/3;
  }
  .poster {
    width: 300px;
    grid-column: 1 / 2;
    grid-row: 3 / 4;
    margin: 1rem 2rem 0;
  }
  .content {
    grid-column: 2 / 3;
    grid-row: 3 / 4;
  }

  .cta {
    grid-column: 1 / 2;
    grid-row: 4 / 5;
    margin: 1rem 2rem;
  }

  .dato {
    margin: 1rem 2rem;
  }

  h1 {
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.9;

    margin: 1rem 2rem 0;
  }

  p {
    line-height: 1.8;
  }

  h3 {
    font-size: 2rem;
    margin: 1rem 1rem 0.5rem 0;
  }

  .bar-section {
    width: 100%;
    margin-top: 4rem;
  }

  .bar-image {
    width: 100%;
    object-fit: cover;
  }

  .events {
    padding: 6rem 4rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .events h2 {
    font-size: 3rem;
    margin: 0;
  }

  @media (max-width: 900px) {
    .poster img {
      width: 220px;
    }

    h3 {
      font-size: 1.5rem;
    }

    .events {
      padding: 4rem 2rem;
    }

    .events h2 {
      font-size: 2rem;
    }
  }
</style>
