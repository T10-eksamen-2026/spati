---
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Button from "../../components/Button.astro";
import EventKarrusel from "../../components/EventKarrusel.astro";

const options = {
  headers: {
    apikey: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpqbXpqZXl3em9ubWhyeHBpZG1lIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgzMzM1NDMsImV4cCI6MjA5MzkwOTU0M30._zazZivT85MElhidAI4pC61XTiWwx7NmS19ru3aUjPo",
  },
};

export async function getStaticPaths() {
  const options = {
    headers: {
      apikey: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpqbXpqZXl3em9ubWhyeHBpZG1lIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgzMzM1NDMsImV4cCI6MjA5MzkwOTU0M30._zazZivT85MElhidAI4pC61XTiWwx7NmS19ru3aUjPo",
    },
  };

  const response = await fetch("https://zjmzjeywzonmhrxpidme.supabase.co/rest/v1/event_card", options);
  const data = await response.json();

  return data.map((event: any) => ({
    params: { single: String(event.id) },
    props: { event },
  }));
}

interface Event {
  id: number;
  titel: string;
  teaser: string;
  info: string;
  billede: string;
  type: string;
  dato: string;
  tid: string;
  href: string;
}

interface Props {
  event: Event;
}

const { event } = Astro.props as Props;

const allEventsResponse = await fetch("https://zjmzjeywzonmhrxpidme.supabase.co/rest/v1/event_card", options);
const allEvents = await allEventsResponse.json();

const specialEvents = allEvents
  .filter((e: any) => e.type === "special" && e.id !== event.id)
  .map((e: any) => ({
    title: e.titel,
    text: e.teaser,
    info: e.info,
    dato: e.dato,
    tid: e.tid,
    image: e.billede,
    type: e.type,
    href: `/event/${e.id}`,
  }));
---

<html lang="da">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="/style/general.css" />
    <title>{event.titel}</title>
  </head>

  <body>
    <Header />

    <main>
      <section class="event-hero">
        <div class="event-header">
          <h1>{event.titel}</h1>
          <p class="dato">{event.dato} kl. {event.tid}</p>
        </div>

        <img class="poster" src={event.billede} alt={event.titel} />

        <div class="event-body">
          <p class="beskrivelse">{event.info}</p>
          <h3 class="adresse">Vedbækgade 4, 2200 København N</h3>
          <div class="cta">
            <Button label="tilmeld" href={event.href} size="small" />
          </div>
        </div>
      </section>

      <section class="bar-section">
        <img src="/img/bar.png" alt="illustration af bar" class="bar-image" />
      </section>

      <section class="events">
        <h2>upcoming events</h2>
        <EventKarrusel events={specialEvents} titel=" " />
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background-color: var(--color-text-inverted);
    padding-top: 160px;
  }

  .event-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 1fr;
    gap: 0 clamp(2rem, 4vw, 4rem);
    padding: clamp(3rem, 6vw, 6rem) clamp(2rem, 5vw, 5rem) clamp(1.5rem, 3vw, 3rem) clamp(1.5rem, 4vw, 4rem);
    max-width: 1400px;
    margin: 0 auto;
  }

  .event-header {
    grid-column: 2;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .poster {
    grid-column: 1;
    grid-row: 1 / 3;
    max-width: none;
    object-fit: cover;
    align-self: start;
    display: block;
  }

  .event-body {
    grid-column: 2;
    grid-row: 2;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-top: 2rem;
  }

  .dato {
    font-family: "lacquer", sans-serif;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .beskrivelse {
    max-width: 48ch;
  }

  .cta {
    display: flex;
  }

  .bar-section {
    width: 100%;
  }

  .bar-image {
    width: 100%;
    object-fit: cover;
    margin-top: 6rem;
  }

  .events {
    padding: 6rem 4rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .events h2 {
    margin: 0;
  }

  @media (max-width: 800px) {
    .event-hero {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 1rem 1.5rem;
      padding: 1.5rem;
    }

    .event-header {
      grid-column: 1 / 3;
      grid-row: 1;
    }

    .poster {
      grid-column: 1;
      grid-row: 2;
      max-width: 100%;
      width: 100%;
    }

    .event-body {
      grid-column: 2;
      grid-row: 2;
      padding-top: 0;
      gap: 1rem;
    }

    .events {
      padding: 4rem 1.5rem;
    }
  }
</style>
